# Datajud API Configuration
DATAJUD_API_KEY=sua_chave_api_aqui
DATAJUD_TIMEOUT_MS=35000
DATAJUD_RETRY_ATTEMPTS=2
DATAJUD_RETRY_BACKOFF_MS=1200

# OpenRouter AI Configuration
OPENROUTER_API_KEY=sua_chave_openrouter_aqui
OPENROUTER_MODEL=google/gemma-2-9b-it:free
OPENROUTER_FALLBACK_MODELS=microsoft/phi-3-mini-128k-instruct:free,qwen/qwen-2.5-7b-instruct:free,openrouter/auto
OPENROUTER_TIMEOUT_MS=15000
OPENROUTER_SITE_URL=http://localhost:3000
OPENROUTER_APP_NAME=juriszap-backend

# Supabase Configuration
SUPABASE_URL=https://seu-projeto.supabase.co
SUPABASE_ANON_KEY=sua_chave_publica_supabase

# Server Configuration
PORT=3000
NODE_ENV=development
LOG_LEVEL=debug

# Segurança HTTP
# Em produção, defina as origens permitidas separadas por vírgula
# Exemplo: CORS_ORIGINS=https://app.juriszap.com,https://admin.juriszap.com
CORS_ORIGINS=

# Limite de requisições por janela (aplicado em /api)
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100

# Diretório local para armazenar sessões do WhatsApp (Baileys)
WHATSAPP_AUTH_DIR=.whatsapp-sessions

# Nexano Payment Gateway
NEXANO_PUBLIC_KEY=sua_chave_publica
NEXANO_SECRET_KEY=sua_chave_secreta
NEXANO_WEBHOOK_TOKEN=seu_token_de_seguranca_webhook

